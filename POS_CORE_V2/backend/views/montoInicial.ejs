<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Ingresar Monto Inicial</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

  <div class="container mt-5">
    <div class="card shadow p-4">
      <h3 class="text-center mb-4">💰 Monto Inicial de Caja</h3>

      <% if (typeof error !== 'undefined') { %>
        <div class="alert alert-danger">
          <%= error %>
        </div>
      <% } %>

      <form action="/monto-inicial" method="POST">
        <div class="mb-3">
          <label for="monto" class="form-label">Ingrese el monto inicial:</label>
          <input type="number" step="0.01" min="0" class="form-control" id="monto" name="monto" required autofocus>
        </div>

        <div class="d-flex justify-content-between align-items-center">
          <span>Usuario: <strong><%= user.name %> (<%= user.role %>)</strong></span>
          <button type="submit" class="btn btn-primary">Continuar</button>
        </div>
      </form>
    </div>
  </div>

</body>
</html>
