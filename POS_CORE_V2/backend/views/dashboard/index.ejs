<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .card-metric {
      border-radius: 1rem;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
  </style>
</head>
<body>
  <div class="container mt-5">
    <%- include('../partials/header', { currentUrl: '/dashboard' }) %>

    <h2 class="mb-4">📊 Dashboard</h2>

    <!-- Métricas resumen -->
    <div class="row mb-4">
      <div class="col-md-6 mb-2">

        <div class="card card-metric text-white bg-primary">
          <div class="card-body">
            <h5 class="card-title">Total de Ventas</h5>
            <p class="card-text fs-4 mb-0"><%= totalVentas %></p>

          </div>
        </div>
      </div>
      <div class="col-md-6 mb-2">

        <div class="card card-metric text-white bg-success">
          <div class="card-body">
            <h5 class="card-title">Ingresos Totales</h5>
            <p class="card-text fs-4 mb-0">$<%= ingresosTotales.toFixed(2) %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabla productos más vendidos -->
    <div class="card mb-4">
      <div class="card-header bg-dark text-white">
        🏆 Productos Más Vendidos
      </div>
      <div class="card-body p-0">
        <table class="table table-striped m-0">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Producto</th>
              <th>Total Vendido</th>
            </tr>
          </thead>
          <tbody>
            <% if (productosMasVendidos.length === 0) { %>
              <tr><td colspan="3" class="text-center text-muted">No hay ventas aún.</td></tr>
            <% } else { %>
              <% productosMasVendidos.forEach((p, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= p.nombre %></td>
                  <td><%= p.totalVendido %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

   <!-- Gráfica de barras -->
<div class="card mb-5">
  <div class="card-header bg-primary text-white">
    📊 Gráfica: Productos Más Vendidos
  </div>
  <div class="card-body text-center" style="height: 220px;">
    <canvas id="productosChart" style="max-height: 100%; max-width: 500px; margin: 0 auto;"></canvas>
  </div>
</div>

<!-- Gráfica de pastel -->
<div class="card mb-5 text-center">
  <div class="card-header bg-warning text-white">
    🧾 Gráfica: Distribución por Método de Pago
  </div>
  <div class="card-body">
    <canvas id="metodoPagoChart" height="100" style="max-width: 400px; margin: 0 auto;"></canvas>
  </div>
</div>


    <a href="/products" class="btn btn-secondary">⬅ Volver al Inventario</a>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

 <script>
  // Variables inyectadas desde el servidor (EJS)
  var labels = <%- JSON.stringify(productosMasVendidos.map(p => p.nombre)) %>;
  var data = <%- JSON.stringify(productosMasVendidos.map(p => p.totalVendido)) %>;
</script>

<script>
  const ctx = document.getElementById('productosChart').getContext('2d');

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'Unidades Vendidas',
        data: data,
        backgroundColor: 'rgba(54, 162, 235, 0.6)',
        borderColor: 'rgba(54, 162, 235, 1)',
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            stepSize: 1
          }
        }
      },
      plugins: {
        legend: {
          display: false
        }
      }
    }
  });
</script>

<script>
  // Datos de método de pago
  const metodoLabels = <%- JSON.stringify(Object.keys(metodosPago)) %>;
  const metodoData = <%- JSON.stringify(Object.values(metodosPago)) %>;

  const ctxPie = document.getElementById('metodoPagoChart').getContext('2d');

  new Chart(ctxPie, {
    type: 'pie',
    data: {
      labels: metodoLabels,
      datasets: [{
        label: 'Métodos de Pago',
        data: metodoData,
        backgroundColor: [
          'rgba(255, 99, 132, 0.6)',   // Efectivo
          'rgba(54, 162, 235, 0.6)',   // Tarjeta
          'rgba(255, 206, 86, 0.6)',   // Transferencia
          'rgba(75, 192, 192, 0.6)'    // Mixto
        ],
        borderColor: 'rgba(255, 255, 255, 1)',
        borderWidth: 1
      }]
    },
    options: {
      plugins: {
        legend: {
          position: 'bottom'
        }
      }
    }
  });
</script>


</body>
</html>
