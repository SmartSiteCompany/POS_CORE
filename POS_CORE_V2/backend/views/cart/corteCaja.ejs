<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Corte de Caja</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-5">
  <h2 class="text-center mb-4">Corte de Caja</h2>

  <% if (usuario.role === 'administrador') { %>
    <form method="GET" class="row g-3 mb-4">
      <!-- filtros -->
      <div class="col-md-3">
        <label>Usuario</label>
        <select name="user" class="form-select">
          <option value="">Todos</option>
          <% usuarios.forEach(u => { %>
            <option value="<%= u._id %>" <%= selectedUser == u._id ? 'selected' : '' %>><%= u.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label>Desde</label>
        <input type="date" name="desde" class="form-control" value="<%= desde %>">
      </div>
      <div class="col-md-2">
        <label>Hasta</label>
        <input type="date" name="hasta" class="form-control" value="<%= hasta %>">
      </div>
      <div class="col-md-3">
        <label>Producto (nombre o ID)</label>
        <input type="text" name="producto" class="form-control" placeholder="Buscar producto" value="<%= producto %>">
      </div>
      <div class="col-md-2 d-grid align-items-end">
        <button type="submit" class="btn btn-primary">Filtrar</button>
      </div>
    </form>

    <!-- Tabla completa solo para administrador -->
    <table class="table table-bordered table-striped">
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Usuario</th>
          <th>Método de Pago</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% ventas.forEach(v => { %>
          <tr>
            <td><%= v.date.toLocaleString() %></td>
            <td><%= v.user?.name || 'N/A' %></td>
            <td><%= v.paymentMethod %></td>
            <td>$<%= v.total.toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <!-- Totales visibles para ambos -->
  <div class="mt-4">
    <h5>Monto Inicial: $<%= montoInicial.toFixed(2) %></h5>
    <h5>Total Ventas: $<%= totalAcumulado.toFixed(2) %></h5>
    <h4 class="text-primary">TOTAL CON MONTO INICIAL: $<%= totalConMontoInicial.toFixed(2) %></h4>
    <ul>
      <li>Efectivo: $<%= totalesPorMetodo.efectivo.toFixed(2) %></li>
      <li>Tarjeta: $<%= totalesPorMetodo.tarjeta.toFixed(2) %></li>
      <li>Transferencia: $<%= totalesPorMetodo.transferencia.toFixed(2) %></li>
      <li>Mixto: $<%= totalesPorMetodo.mixto.toFixed(2) %></li>
    </ul>
  </div>

  <% if (usuario.role === 'administrador') { %>
    <div class="mt-4">
      <a href="/api/sales/corte-caja/pdf?<%= `user=${selectedUser}&desde=${desde}&hasta=${hasta}&producto=${producto}` %>" class="btn btn-danger me-2">Exportar PDF</a>
      <a href="/api/sales/corte-caja/excel?<%= `user=${selectedUser}&desde=${desde}&hasta=${hasta}&producto=${producto}` %>" class="btn btn-success">Exportar Excel</a>
    </div>

    <div class="mt-5">
      <h4>Montos Iniciales por Usuario</h4>
      <table class="table table-sm table-bordered">
        <thead>
          <tr>
            <th>Usuario</th>
            <th>Monto Inicial</th>
          </tr>
        </thead>
        <tbody>
          <% usuarios.forEach(u => { %>
            <tr>
              <td><%= u.name %></td>
              <td>$<%= (u.montoInicial || 0).toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <a href="/products" class="btn btn-secondary mt-4">⬅ Volver a productos</a>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
