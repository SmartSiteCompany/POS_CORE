<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Compra Exitosa</title>
  <link rel="stylesheet" href="/styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script>
    function descargarTicket(tipo) {
      window.location.href = `/ticket/download?type=${tipo}`;
    }
  </script>
</head>
<body class="container mt-5">

  <h2 class="mb-4 text-success">✅ ¡Gracias por tu compra!</h2>
  <p><strong>🗓 Fecha:</strong> <%= ticket.fecha %></p>

  <h4>🧾 Detalle del Ticket:</h4>
  <ul>
    <% if (ticket.cart && Array.isArray(ticket.cart)) { %>
      <% ticket.cart.forEach(item => { %>
        <li>
          <%= item.name %> - $<%= item.priceAtSale.toFixed(2) %> x <%= item.quantity %>
          = $<%= (item.priceAtSale * item.quantity).toFixed(2) %>
        </li>
      <% }) %>
    <% } else { %>
      <li>⚠️ No hay productos en el ticket</li>
    <% } %>
  </ul>

  <p><strong>Subtotal:</strong> $<%= ticket.subtotal.toFixed(2) %></p>
  <p><strong>Impuestos (16%):</strong> $<%= ticket.tax.toFixed(2) %></p>
  <h4><strong>Total:</strong> $<%= ticket.total.toFixed(2) %></h4>

  <hr>

  <h4>💳 Métodos de Pago:</h4>
  <ul>
    <% if (ticket.pagoEfectivo > 0) { %>
      <li>Efectivo: $<%= ticket.pagoEfectivo.toFixed(2) %></li>
    <% } %>
    <% if (ticket.pagoTarjeta > 0) { %>
      <li>Tarjeta: $<%= ticket.pagoTarjeta.toFixed(2) %></li>
    <% } %>
    <% if (ticket.pagoTransferencia > 0) { %>
      <li>Transferencia: $<%= ticket.pagoTransferencia.toFixed(2) %></li>
    <% } %>
  </ul>

  <p><strong>Total recibido:</strong>
    $<%= (
      ticket.pagoEfectivo + ticket.pagoTarjeta + ticket.pagoTransferencia
    ).toFixed(2) %>
  </p>

  <p><strong>💵 Cambio entregado:</strong> $<%= ticket.cambio.toFixed(2) %></p>

  <hr>

  <button onclick="descargarTicket('pdf')" class="btn btn-outline-primary">📄 Descargar PDF</button>
  <button onclick="descargarTicket('json')" class="btn btn-outline-secondary">📦 Descargar JSON</button>
  <button onclick="window.location.href='/cart/reprint-ticket'" class="btn btn-outline-success mt-2">🔁 Reimprimir Ticket</button>

  <br><br>

 <script>
  // Redirige automáticamente después de 3 segundos a la lista de productos
  setTimeout(() => {
    window.location.href = '/products';
  }, 6000);
</script>

</body>
</html>
