<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Pago Mixto</title>
  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="container mt-5">

  <h2 class="mb-4">💳 Pago Mixto</h2>
  <p><strong>Total a pagar:</strong> $<span id="totalMostrar"><%= total.toFixed(2) %></span></p>

  <form action="/cart/checkout" method="POST" id="formPago">
    <input type="hidden" name="tipoPago" value="mixto">
    <input type="hidden" name="total" id="totalOculto" value="<%= total.toFixed(2) %>">

    <div class="mb-3">
      <label for="montoEfectivo" class="form-label">Efectivo:</label>
      <input type="number" step="0.01" name="montoEfectivo" id="montoEfectivo" class="form-control payment-input" value="0">
    </div>

    <div class="mb-3">
      <label for="montoTarjeta" class="form-label">Tarjeta:</label>
      <input type="number" step="0.01" name="montoTarjeta" id="montoTarjeta" class="form-control payment-input" value="0">
    </div>

    <div class="mb-3">
      <label for="montoTransferencia" class="form-label">Transferencia:</label>
      <input type="number" step="0.01" name="montoTransferencia" id="montoTransferencia" class="form-control payment-input" value="0">
    </div>

    <div class="mb-3">
      <strong>Total ingresado:</strong> $<span id="totalIngresado">0.00</span><br>
      <strong>Cambio:</strong> $<span id="cambio">0.00</span><br>
      <strong>Falta por pagar:</strong> $<span id="restante">0.00</span>
    </div>

    <button type="submit" class="btn btn-success" id="btnFinalizar">✅ Finalizar compra</button>
    <a href="/cart/view" class="btn btn-secondary">⬅ Cancelar</a>
  </form>

  <script>
    const total = parseFloat(document.getElementById("totalOculto").value);
    const inputs = document.querySelectorAll('.payment-input');
    const totalIngresadoEl = document.getElementById('totalIngresado');
    const cambioEl = document.getElementById('cambio');
    const restanteEl = document.getElementById('restante');
    const btnFinalizar = document.getElementById('btnFinalizar');

    function calcular() {
      let suma = 0;
      const efectivo = parseFloat(document.getElementById('montoEfectivo').value) || 0;
      let tarjeta = parseFloat(document.getElementById('montoTarjeta').value) || 0;
      const transferencia = parseFloat(document.getElementById('montoTransferencia').value) || 0;

      if (tarjeta > total) {
        tarjeta = total;
        document.getElementById('montoTarjeta').value = tarjeta.toFixed(2);
      }

      suma = efectivo + tarjeta + transferencia;
      const cambio = suma > total ? (suma - total) : 0;
      const restante = total - suma > 0 ? total - suma : 0;

      totalIngresadoEl.textContent = suma.toFixed(2);
      cambioEl.textContent = cambio.toFixed(2);
      restanteEl.textContent = restante.toFixed(2);

      btnFinalizar.disabled = restante > 0;
    }

    inputs.forEach(input => {
      input.addEventListener("input", calcular);
    });

    calcular(); // inicial
  </script>

</body>
</html>
