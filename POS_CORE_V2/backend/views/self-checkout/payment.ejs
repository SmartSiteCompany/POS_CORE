<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>💳 Pago - Autocobro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .metodo-btn {
      width: 100%;
      padding: 1rem;
      font-size: 1.2rem;
    }
  </style>
</head>
<body class="container mt-4">
  <h2 class="mb-4 text-center">💳 Pago</h2>

  <p><strong>Total a pagar:</strong> $<%= total.toFixed(2) %></p>

  <form action="/self-checkout/payment" method="POST">
    <div class="mb-3">
      <label class="form-label">Método de Pago:</label>
      <select name="metodo" class="form-select" required>
        <option value="">-- Selecciona --</option>
        <option value="efectivo">💵 Efectivo</option>
        <option value="tarjeta">💳 Tarjeta</option>
        <option value="transferencia">🏦 Transferencia</option>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label">Monto recibido:</label>
      <input type="number" name="monto" step="0.01" class="form-control" required>
    </div>

    <div class="d-flex justify-content-between">
      <a href="/self-checkout/cart" class="btn btn-secondary">⬅ Volver al carrito</a>
      <button class="btn btn-success btn-lg">✅ Confirmar pago</button>
    </div>
  </form>
</body>
</html>
