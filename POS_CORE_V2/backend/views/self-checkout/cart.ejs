<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>🛒 Carrito - Autocobro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">
  <h2 class="mb-4 text-center">🧾 Resumen de tu carrito</h2>

  <% if (cart.length === 0) { %>
    <div class="alert alert-warning">Tu carrito está vacío.</div>
    <a href="/self-checkout/products" class="btn btn-primary">⬅ Volver a productos</a>
  <% } else { %>
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Producto</th>
          <th>Precio</th>
          <th>Cantidad</th>
          <th>Subtotal</th>
          <th>Acción</th>
        </tr>
      </thead>
      <tbody>
        <% cart.forEach(item => { %>
          <tr>
            <td><%= item.product.name %></td>
            <td>$<%= item.product.pricePieza.toFixed(2) %></td>
            <td><%= item.quantity %></td>
            <td>$<%= (item.product.pricePieza * item.quantity).toFixed(2) %></td>
            <td>
              <form method="POST" action="/self-checkout/remove-from-cart/<%= item.product._id %>">
                <button class="btn btn-sm btn-danger">🗑️</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="text-end mb-4">
      <p><strong>Subtotal:</strong> $<%= subtotal.toFixed(2) %></p>
      <p><strong>Impuestos (16%):</strong> $<%= tax.toFixed(2) %></p>
      <h4><strong>Total:</strong> $<%= total.toFixed(2) %></h4>
    </div>

    <div class="d-flex justify-content-between">
      <a href="/self-checkout/products" class="btn btn-secondary">⬅ Seguir comprando</a>
      <a href="/self-checkout/payment" class="btn btn-success btn-lg">💳 Ir a pagar</a>
    </div>
  <% } %>
</body>
</html>
