<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>✅ Compra Exitosa - Autocobro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">

  <div class="text-center">
    <h2 class="text-success mb-4">✅ ¡Gracias por tu compra!</h2>
    <p><strong>🗓 Fecha:</strong> <%= ticket.fecha %></p>
  </div>

  <h4>🧾 Productos:</h4>
  <ul>
    <% ticket.cart.forEach(item => { %>
      <li>
        <%= item.product.name %> x <%= item.quantity %> — $<%= (item.product.pricePieza * item.quantity).toFixed(2) %>
      </li>
    <% }) %>
  </ul>

  <p><strong>Subtotal:</strong> $<%= ticket.subtotal.toFixed(2) %></p>
  <p><strong>Impuestos (16%):</strong> $<%= ticket.tax.toFixed(2) %></p>
  <h4><strong>Total:</strong> $<%= ticket.total.toFixed(2) %></h4>

  <p><strong>Método de pago:</strong> <%= ticket.metodo %></p>
  <p><strong>Pagado:</strong> $<%= ticket.montoIngresado.toFixed(2) %></p>
  <p><strong>Cambio:</strong> $<%= ticket.cambio.toFixed(2) %></p>


  <div class="text-center mt-4">
  <button class="btn btn-outline-secondary" onclick="mostrarQR()">🔗 Mostrar QR</button>
</div>

<div id="qrContenedor" class="text-center mt-3"></div>

<script>
  function mostrarQR() {
    fetch('/self-checkout/qr-ticket')
      .then(res => res.text())
      .then(html => {
        document.getElementById('qrContenedor').innerHTML = html;
      })
      .catch(err => {
        console.error('❌ Error mostrando QR:', err);
        alert('No se pudo generar el QR');
      });
  }
</script>


  <div class="text-center mt-5">
    <a href="/self-checkout/products" class="btn btn-primary btn-lg">🛒 Nueva compra</a>
  </div>

</body>
</html>
