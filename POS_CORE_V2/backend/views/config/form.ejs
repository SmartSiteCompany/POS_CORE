<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Configuración del Negocio</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .low-stock { background-color: #fff3cd; }
    .no-stock { background-color: #f8d7da; }
    .highlight strong {
      background-color: yellow;
      color: black;
    }
  </style>
</head>
<body>
  <div class="container vintage mt-5">
    <%- include('../partials/header') %>

    <h2 class="mb-4">Configuración del Negocio</h2>

    <% if (typeof successMessage !== 'undefined') { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= successMessage %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <form action="/config" method="POST" class="mt-4">
      <div class="mb-3">
        <label class="form-label">Nombre del Negocio</label>
        <input type="text" name="businessName" class="form-control" required value="<%= config?.businessName || '' %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Nombre en el Ticket</label>
        <input type="text" name="ticketName" class="form-control" required value="<%= config?.ticketName || '' %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Impuesto (%)</label>
        <input type="number" name="taxRate" class="form-control" required value="<%= config?.taxRate || '' %>">
      </div>

      <button class="btn btn-primary">💾 Guardar Configuración</button>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <% if (typeof successMessage !== 'undefined') { %>
    <script>
      setTimeout(() => {
        window.location.href = "/products";
      }, 2500);
    </script>
  <% } %>
</body>
</html>
