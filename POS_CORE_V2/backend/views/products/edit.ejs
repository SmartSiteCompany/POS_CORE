<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Editar Producto</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container vintage mt-5">
    <h1>✏️ Editar Producto</h1>

    <form action="/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">

      <div class="mb-3">
        <label class="form-label">Nombre*</label>
        <input type="text" name="name" class="form-control" required value="<%= product.name %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Precio por pieza*</label>
        <input type="number" step="0.01" name="pricePieza" class="form-control" required value="<%= product.pricePieza %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Precio mayoreo</label>
        <input type="number" step="0.01" name="priceMayoreo" class="form-control" value="<%= product.priceMayoreo %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Precio paquete (opcional)</label>
        <input type="number" step="0.01" name="pricePaquete" class="form-control" value="<%= product.pricePaquete %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Precio 4 (opcional)</label>
        <input type="number" step="0.01" name="price4" class="form-control" value="<%= product.price4 %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Precio 5 (opcional)</label>
        <input type="number" step="0.01" name="price5" class="form-control" value="<%= product.price5 %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Cantidad mínima para mayoreo</label>
        <input type="number" name="minMayoreo" class="form-control" value="<%= product.minMayoreo %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Cantidad mínima para paquete</label>
        <input type="number" name="minPaquete" class="form-control" value="<%= product.minPaquete %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Cantidad mínima para precio 4</label>
        <input type="number" name="min4" class="form-control" value="<%= product.min4 %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Cantidad mínima para precio 5</label>
        <input type="number" name="min5" class="form-control" value="<%= product.min5 %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Categoría*</label>
        <input type="text" name="category" class="form-control" required value="<%= product.category %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Stock</label>
        <input type="number" name="stock" class="form-control" value="<%= product.stock %>">
      </div>

      <div class="mb-3">
        <label for="stockMin" class="form-label">Inv. Mínimo</label>
        <input type="number" name="stockMin" id="stockMin" class="form-control" value="<%= product.stockMin %>">
      </div>

      <div class="mb-3">
        <label for="stockMax" class="form-label">Inv. Máximo</label>
        <input type="number" name="stockMax" id="stockMax" class="form-control" value="<%= product.stockMax %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Código de barras*</label>
        <input type="text" name="barcode" class="form-control" required value="<%= product.barcode %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Descripción</label>
        <textarea name="description" class="form-control" rows="2"><%= product.description || '' %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Imagen del producto</label>
        <input type="file" name="image" accept="image/*" class="form-control">
        <% if (product.image) { %>
          <div class="mt-2">
            <img src="/uploads/<%= product.image %>" alt="Imagen actual" width="120">
          </div>
        <% } %>
      </div>

      <button class="btn btn-primary">💾 Guardar cambios</button>
      <a href="/products" class="btn btn-secondary ms-2">↩️ Cancelar</a>
    </form>
  </div>
  <script>
  document.querySelector('form').addEventListener('submit', function (e) {
    const min = parseInt(document.getElementById('stockMin').value, 10);
    const max = parseInt(document.getElementById('stockMax').value, 10);

    if (!isNaN(min) && !isNaN(max) && min >= max) {
      e.preventDefault();
      alert('⚠️ El inventario mínimo debe ser menor que el inventario máximo.');
    }
  });
</script>

</body>
</html>
