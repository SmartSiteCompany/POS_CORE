<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Usuarios</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .low-stock { background-color: #fff3cd; }
    .no-stock { background-color: #f8d7da; }
    .highlight strong {
      background-color: yellow;
      color: black;
    }
  </style>
</head>
<body>
  <div class="container vintage mt-5">
    <%- include('../partials/header') %>

    <h1 class="mb-4">Usuarios del sistema</h1>
    <a href="/users/new" class="btn btn-primary mb-3">➕ Nuevo Usuario</a>

   <table class="table table-bordered">
  <thead>
    <tr>
      <th>Imagen</th>
      <th>Nombre</th>
      <th>Email</th>
      <th>Rol</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(user => { %>
      <tr>
        <td>
          <% if (user.image) { %>
            <img src="/uploads/<%= user.image %>" width="60">
          <% } else { %>
            <span>Sin imagen</span>
          <% } %>
        </td>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user.role %></td>
        <td>
          <a href="/users/edit/<%= user._id %>" class="btn btn-sm btn-warning">✏️ Editar</a>
          <form action="/users/delete/<%= user._id %>" method="POST" style="display:inline;">
            <button class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este usuario?')">🗑️ Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
